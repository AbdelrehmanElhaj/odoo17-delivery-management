<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_order_form_delivery" model="ir.ui.view">
        <field name="name">sale.order.form.delivery</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Smart button: delivery count -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" name="action_view_deliveries"
                        class="oe_stat_button" icon="fa-truck"
                        groups="delivery_management.group_delivery_manager"
                        invisible="delivery_count == 0">
                    <field name="delivery_count" widget="statinfo" string="Deliveries"/>
                </button>
            </xpath>

            <!-- "Create Delivery" button in the header, visible on confirmed orders -->
            <xpath expr="//button[@name='action_confirm']" position="after">
                <button name="action_create_delivery" string="Create Delivery" type="object"
                        class="btn-secondary"
                        groups="delivery_management.group_delivery_manager"
                        invisible="state not in ['sale', 'done']"/>
            </xpath>

        </field>
    </record>

</odoo>

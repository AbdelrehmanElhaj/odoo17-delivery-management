<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="view_delivery_driver_list" model="ir.ui.view">
        <field name="name">delivery.driver.list</field>
        <field name="model">delivery.driver</field>
        <field name="arch" type="xml">
            <tree string="Drivers" decoration-muted="not active">
                <field name="name"/>
                <field name="phone"/>
                <field name="vehicle_id"/>
                <field name="user_id"/>
                <field name="current_trip_id"/>
                <field name="active" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_delivery_driver_form" model="ir.ui.view">
        <field name="name">delivery.driver.form</field>
        <field name="model">delivery.driver</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Driver name…"/></h1>
                    </div>
                    <group>
                        <group string="Contact">
                            <field name="phone"/>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Assignment">
                            <field name="vehicle_id"/>
                            <field name="current_trip_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_delivery_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">delivery.driver</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>

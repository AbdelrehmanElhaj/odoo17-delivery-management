<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Standalone list view (used in trip form via notebook) -->
    <record id="view_delivery_stop_list" model="ir.ui.view">
        <field name="name">delivery.stop.list</field>
        <field name="model">delivery.stop</field>
        <field name="arch" type="xml">
            <tree string="Stops" editable="bottom"
                  decoration-success="status == 'done'"
                  decoration-danger="status == 'failed'"
                  decoration-warning="status == 'arrived'">
                <field name="sequence" widget="handle"/>
                <field name="partner_id"/>
                <field name="order_id" optional="show"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'done'"
                       decoration-danger="status == 'failed'"
                       decoration-warning="status == 'arrived'"
                       decoration-info="status == 'pending'"/>
                <field name="eta" optional="show"/>
                <field name="actual_arrival" optional="show"/>
                <field name="photo_count" string="Photos" optional="show"/>
                <field name="notes" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_delivery_stop_form" model="ir.ui.view">
        <field name="name">delivery.stop.form</field>
        <field name="model">delivery.stop</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_arrive" string="Mark Arrived" type="object"
                            class="btn-primary" invisible="status != 'pending'"/>
                    <button name="action_done" string="Mark Done" type="object"
                            class="btn-primary" invisible="status != 'arrived'"/>
                    <button name="action_failed" string="Mark Failed" type="object"
                            class="btn-danger" invisible="status in ['done', 'failed']"/>
                    <button name="action_reset_pending" string="Reset to Pending" type="object"
                            invisible="status == 'pending'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,arrived,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Stop Info">
                            <field name="trip_id" readonly="1"/>
                            <field name="order_id"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Address">
                            <field name="partner_id"/>
                            <field name="partner_lat"/>
                            <field name="partner_lng"/>
                        </group>
                        <group string="Timing">
                            <field name="eta"/>
                            <field name="actual_arrival"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Photos" name="photos">
                            <field name="photo_ids">
                                <tree>
                                    <field name="image" widget="image" options="{'size': [64, 64]}"/>
                                    <field name="taken_at"/>
                                    <field name="taken_by"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_delivery_stop" model="ir.actions.act_window">
        <field name="name">Stops</field>
        <field name="res_model">delivery.stop</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>

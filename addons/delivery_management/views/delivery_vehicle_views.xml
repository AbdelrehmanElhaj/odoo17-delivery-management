<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="view_delivery_vehicle_list" model="ir.ui.view">
        <field name="name">delivery.vehicle.list</field>
        <field name="model">delivery.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Vehicles" decoration-muted="not active">
                <field name="name"/>
                <field name="plate"/>
                <field name="capacity"/>
                <field name="traccar_device_id"/>
                <field name="last_lat" optional="show"/>
                <field name="last_lng" optional="show"/>
                <field name="gps_updated" optional="show"/>
                <field name="driver_count" string="Drivers"/>
                <field name="active" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_delivery_vehicle_form" model="ir.ui.view">
        <field name="name">delivery.vehicle.form</field>
        <field name="model">delivery.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_drivers"
                                class="oe_stat_button" icon="fa-id-card"
                                invisible="driver_count == 0">
                            <field name="driver_count" widget="statinfo" string="Drivers"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Vehicle name…"/></h1>
                    </div>
                    <group>
                        <group string="Vehicle Info">
                            <field name="plate"/>
                            <field name="capacity"/>
                            <field name="active"/>
                        </group>
                        <group string="GPS / Traccar">
                            <field name="traccar_device_id"/>
                            <field name="last_lat"/>
                            <field name="last_lng"/>
                            <field name="gps_updated"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Drivers" name="drivers">
                            <field name="driver_ids" context="{'default_vehicle_id': id}">
                                <tree>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="user_id"/>
                                    <field name="current_trip_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_delivery_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">delivery.vehicle</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>

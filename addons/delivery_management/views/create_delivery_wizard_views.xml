<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_create_delivery_wizard_form" model="ir.ui.view">
        <field name="name">create.delivery.wizard.form</field>
        <field name="model">create.delivery.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Delivery Order">
                <group>
                    <field name="sale_order_id" readonly="1"/>
                    <field name="partner_id"/>
                    <field name="mode" widget="radio" options="{'horizontal': True}"/>
                    <field name="scheduled_date"/>
                </group>
                <group string="Notes">
                    <field name="notes" nolabel="1" placeholder="Optional notes for the driver…"/>
                </group>
                <footer>
                    <button name="action_create" string="Create Delivery" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

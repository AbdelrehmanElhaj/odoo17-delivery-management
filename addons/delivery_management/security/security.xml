<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_delivery" model="ir.module.category">
            <field name="name">Delivery Management</field>
            <field name="sequence">20</field>
        </record>

        <!-- Delivery Manager: full backend access -->
        <record id="group_delivery_manager" model="res.groups">
            <field name="name">Delivery Manager</field>
            <field name="category_id" ref="module_category_delivery"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can create, edit, and delete vehicles, drivers, trips, and orders.</field>
        </record>

        <!-- Delivery Driver: portal user who updates stops -->
        <record id="group_delivery_driver" model="res.groups">
            <field name="name">Delivery Driver</field>
            <field name="category_id" ref="module_category_delivery"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
            <field name="comment">Can view assigned trips and update stop status via portal.</field>
        </record>

        <!-- Record rules: drivers only see their own trips/orders/stops -->
        <record id="rule_delivery_trip_driver" model="ir.rule">
            <field name="name">Delivery Trip: driver sees own trips</field>
            <field name="model_id" ref="model_delivery_trip"/>
            <field name="groups" eval="[(4, ref('group_delivery_driver'))]"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_delivery_order_driver" model="ir.rule">
            <field name="name">Delivery Order: driver sees own orders</field>
            <field name="model_id" ref="model_delivery_order"/>
            <field name="groups" eval="[(4, ref('group_delivery_driver'))]"/>
            <field name="domain_force">[('trip_id.driver_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_delivery_stop_driver" model="ir.rule">
            <field name="name">Delivery Stop: driver sees own stops</field>
            <field name="model_id" ref="model_delivery_stop"/>
            <field name="groups" eval="[(4, ref('group_delivery_driver'))]"/>
            <field name="domain_force">[('trip_id.driver_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
